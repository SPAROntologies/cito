    "@language" : "en",
    "@value" : "stable"
  } ]
}, {
  "@id" : "http://purl.org/spar/cito/isCitedAsPontentialSolutionBy",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://purl.org/vocab/vann/example" : [ {
